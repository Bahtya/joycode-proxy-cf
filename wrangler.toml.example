# Cloudflare Pages 项目配置模板。
# 复制为 wrangler.toml（已 gitignore）并填入你自己的 D1 database_id 和 KV id。
# database_id 来自:  wrangler d1 create joycode-proxy-db
# KV id 来自:        wrangler kv namespace create QR_SESSIONS

name = "joycode-proxy"
compatibility_date = "2026-06-01"
pages_build_output_dir = "./web-build"

[[d1_databases]]
binding = "DB"
database_name = "joycode-proxy-db"
database_id = "YOUR_D1_DATABASE_ID"

[[kv_namespaces]]
binding = "QR_SESSIONS"
id = "YOUR_KV_NAMESPACE_ID"

[vars]
JOYCODE_BASE_URL = "https://api-ai.jd.com"
JOYCODE_CLIENT_VERSION = "2.4.5"
MAX_ACCOUNTS = "10"
DEFAULT_TIMEOUT = "1800"
LOG_RETENTION_DAYS = "30"

# 密钥（用 `wrangler pages secret put` 设置，不要写在这里）：
#   PTKEY_ENC_KEY      = 32 字节 hex（AES-256-GCM 密钥）
#   JWT_SECRET         = 32 字节 hex（HS256 签名密钥）
#   AUTH_PASSWORD_HASH = 可选，预先设好的 bcrypt 哈希；否则首次用 /api/auth/setup 设置
