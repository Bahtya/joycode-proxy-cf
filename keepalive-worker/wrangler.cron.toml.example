# 配套 Cron Worker 配置模板（每 10 分钟刷新 pt_key）。
# 复制为 wrangler.cron.toml（已 gitignore）并填入与 Pages 相同的 D1 database_id。
# Pages Functions 不支持定时任务，所以 keepalive 单独跑在这个 Worker 里。

name = "joycode-keepalive"
main = "src/index.ts"
compatibility_date = "2026-06-01"

[triggers]
crons = ["*/10 * * * *"]

[[d1_databases]]
binding = "DB"
database_name = "joycode-proxy-db"
database_id = "YOUR_D1_DATABASE_ID"   # 必须与 wrangler.toml 里的 database_id 一致

[vars]
JOYCODE_BASE_URL = "https://joycode-api.jd.com"
JOYCODE_CLIENT_VERSION = "2.4.5"

# 密钥（用 `wrangler secret put --config keepalive-worker/wrangler.cron.toml` 设置）：
#   PTKEY_ENC_KEY = 与 Pages 项目相同的值（解密 pt_key 用）
